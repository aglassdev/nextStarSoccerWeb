# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id

# Collection IDs
VITE_APPWRITE_PARENT_USERS_COLLECTION_ID=your_collection_id
VITE_APPWRITE_YOUTH_PLAYERS_COLLECTION_ID=your_collection_id
VITE_APPWRITE_COLLEGIATE_PLAYERS_COLLECTION_ID=your_collection_id
VITE_APPWRITE_PROFESSIONAL_PLAYERS_COLLECTION_ID=your_collection_id
VITE_APPWRITE_COACHES_COLLECTION_ID=your_collection_id
VITE_APPWRITE_TEAM_TRAINING_COLLECTION_ID=your_collection_id
VITE_APPWRITE_SIGNUPS_COLLECTION_ID=your_collection_id
VITE_APPWRITE_CHECKINS_COLLECTION_ID=your_collection_id
VITE_APPWRITE_COACH_SIGNUPS_COLLECTION_ID=your_collection_id
VITE_APPWRITE_COACH_CHECKINS_COLLECTION_ID=your_collection_id
VITE_APPWRITE_MESSAGES_COLLECTION_ID=your_collection_id
VITE_APPWRITE_BILLS_COLLECTION_ID=bills
VITE_APPWRITE_BILL_ITEMS_COLLECTION_ID=bill_items
VITE_APPWRITE_PAYMENTS_COLLECTION_ID=payments

# Family Collections
VITE_APPWRITE_FAMILY_RELATIONSHIPS_COLLECTION_ID=family_relationships_001
VITE_APPWRITE_FAMILY_INVITATIONS_COLLECTION_ID=family_invitations_001

# Scholarship
VITE_APPWRITE_SCHOLARSHIP_COLLECTION_ID=scholarship_applications
VITE_APPWRITE_SCHOLARSHIP_BUCKET_ID=scholarship_documents

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_key

# Google APIs
VITE_GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key
VITE_GOOGLE_CALENDAR_ID=your_google_calendar_id
# Ensure Places API is enabled for this key in Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# reCAPTCHA
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key
